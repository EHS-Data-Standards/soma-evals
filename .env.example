# API keys for LLM providers.
# Set these as env vars or use the llm key store: uv run llm keys set <provider>

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google AI Studio / Gemini
# GEMINI_API_KEY=AI...

# Path to soma schema (default: ../soma/src/soma/schema/)
# SOMA_SCHEMA_PATH=../soma/src/soma/schema/

# Path to soma Excel serialization (default: ../soma/project/excel/soma.xlsx)
# SOMA_EXCEL_PATH=../soma/project/excel/soma.xlsx
